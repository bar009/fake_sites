# Optional: Brave Search API key (https://api.search.brave.com/ - free tier ~2000 queries/month)
# If set and you pass --provider brave, searches go through Brave instead of DuckDuckGo.
BRAVE_API_KEY=

# Local web application data (SQLite, screenshots and exports).
# Defaults to ./data when omitted.
FAKESHOP_DATA_DIR=

# Optional fixed safety deadline for one brand target, in seconds (minimum 30).
# By default the worker uses 120 + (top_n × 45) seconds.
FAKESHOP_TARGET_TIMEOUT_SECONDS=
